generator client {
provider = "prisma-client-js"
}

datasource db {
provider  = "postgresql"
url       = env("DATABASE_URL")
directUrl = env("DIRECT_URL")
}



enum Role {
ADMIN
FUNCIONARIO

@@map("role")
}

enum TipoFazenda {
PROPRIA
ARRENDADA

@@map("tipo_fazenda")
}

enum Cultura {
SOJA
MILHO
CAFE
TRIGO
SORGO

@@map("cultura")
}

enum TipoGasto {
ADUBO
SEMENTES
COMBUSTIVEL
DIESEL
MANUTENCAO

@@map("tipo_gasto")
}

enum StatusGasto {
PAGO
PENDENTE

@@map("status_gasto")
}

enum StatusLembrete {
PENDENTE
ENVIADO
CANCELADO

@@map("status_lembrete")
}



model Usuario {
id        String   @id @default(uuid())
nome      String   @db.VarChar(100)
email     String   @unique @db.VarChar(255)
senha     String   @db.VarChar(255)
role      Role     @default(FUNCIONARIO)
telefone  String?  @db.VarChar(20)
criadoEm  DateTime @default(now()) @map("criado_em")

lembretes Lembrete[]
insumos   InsumoAtividade[]

@@map("usuarios")
}

model Fazenda {
id           String      @id @default(uuid())
nome         String      @db.VarChar(150)
tipo         TipoFazenda
localizacao  String?     @db.VarChar(255)
criadoEm     DateTime    @default(now()) @map("criado_em")
atualizadoEm DateTime    @default(now()) @updatedAt @map("atualizado_em")

colheitas Colheita[]
lembretes Lembrete[]
insumos   InsumoAtividade[]

@@map("fazendas")
}

model Colheita {
id              String   @id @default(uuid())
fazendaId       String   @map("fazenda_id")
cultura         Cultura
area            Decimal  @db.Decimal(10, 2)
sacasProduzidas Decimal  @map("sacas_produzidas") @db.Decimal(10, 2)
ano             Int
dataColheita    DateTime @map("data_colheita") @db.Date
criadoEm        DateTime @default(now()) @map("criado_em")
atualizadoEm    DateTime @default(now()) @updatedAt @map("atualizado_em")

fazenda Fazenda @relation(fields: [fazendaId], references: [id])
gastos  Gasto[]
lucros  Lucro[]

@@map("colheitas")
}

model Gasto {
id             String      @id @default(uuid())
colheitaId     String      @map("colheita_id")
tipo           TipoGasto
valor          Decimal     @db.Decimal(10, 2)
dataVencimento DateTime?   @map("data_vencimento") @db.Date
status         StatusGasto
descricao      String?     @db.Text
data           DateTime    @db.Date
criadoEm       DateTime    @default(now()) @map("criado_em")
atualizadoEm   DateTime    @default(now()) @updatedAt @map("atualizado_em")

colheita Colheita @relation(fields: [colheitaId], references: [id])

@@map("gastos")
}

model Lucro {
id              String   @id @default(uuid())
colheitaId      String   @map("colheita_id")
quantidadeSacas Decimal  @map("quantidade_sacas") @db.Decimal(10, 2)
valorUnitario   Decimal  @map("valor_unitario") @db.Decimal(10, 2)
comprador       String   @db.VarChar(150)
data            DateTime @db.Date
criadoEm        DateTime @default(now()) @map("criado_em")

colheita Colheita @relation(fields: [colheitaId], references: [id])

@@map("lucros")
}

model Lembrete {
id               String         @id @default(uuid())
usuarioId        String         @map("usuario_id")
fazendaId        String?        @map("fazenda_id")
titulo           String         @db.VarChar(150)
descricao        String?        @db.Text
dataLembrete     DateTime       @map("data_lembrete")
telefoneWhatsapp String?        @map("telefone_whatsapp") @db.VarChar(20)
status           StatusLembrete @default(PENDENTE)
criadoEm         DateTime       @default(now()) @map("criado_em")

usuario Usuario  @relation(fields: [usuarioId], references: [id])
fazenda Fazenda? @relation(fields: [fazendaId], references: [id])

@@map("lembretes")
}

model InsumoAtividade {
id            String   @id @default(uuid())
funcionarioId String   @map("funcionario_id")
fazendaId     String   @map("fazenda_id")
item          String   @db.VarChar(150)
quantidade    Decimal  @db.Decimal(10, 2)
observacoes   String?  @db.Text
data          DateTime @db.Date
criadoEm      DateTime @default(now()) @map("criado_em")

funcionario Usuario @relation(fields: [funcionarioId], references: [id])
fazenda     Fazenda @relation(fields: [fazendaId], references: [id])

@@map("insumos_atividades")
}

model Cotacao {
id           String   @id @default(uuid())
valor        Decimal  @db.Decimal(10, 4)
fonte        String   @db.VarChar(100)
atualizadoEm DateTime @default(now()) @map("atualizado_em")

@@map("cotacoes")
}