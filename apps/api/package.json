{
  "name":"api",
  "version":"1.0.0",
  "private":true,
  "type":"module",
  "scripts":{
    "dev":"node --watch src/server.js",
    "start":"node src/server.js",
    "lint":"eslint src",
    "test":"vitest",
    "test:coverage":"vitest --coverage",
    "db:migrate":"prisma migrate dev",
