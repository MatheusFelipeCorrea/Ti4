    "db:studio":"prisma studio",
    "db:seed":"node src/database/seeds/admin.seed.js",
    "db:reset":"prisma migrate reset"
  },
  "dependencies":{
    "@google/generative-ai":"^0.24.1",
    "@prisma/client":"^5.10.0",
    "axios": "^1.7.0",
    "bcryptjs":"^2.4.3",
    "cors":"^2.8.5",
    "dotenv":"^16.4.0",
    "express":"^4.19.0",
    "express-rate-limit":"^7.0.0",
    "helmet":"^7.0.0",
    "jsonwebtoken":"^9.0.0",
    "node-cron":"^4.2.1",
    "pino":"^9.0.0",
    "pino-pretty":"^11.0.0",
    "zod":"^3.23.0"
  },

  "devDependencies": {
    "eslint":"^9.39.3",
    "prisma":"^5.10.0",
    "vitest":"^2.1.9"
  }
}